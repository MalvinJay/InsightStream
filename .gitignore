# Node.js dependencies
**/node_modules/

# Build output
**/dist/
**/build/
**/.next/
**/.nuxt/

# Logs
**/*.log
**/logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS-specific
.DS_Store
Thumbs.db

# Environment files
**/.env
**/.env.local
**/.env.*.local

# IDE/editor folders
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Optional: ignore coverage reports
**/coverage/

# Optional: ignore test snapshots
**/__snapshots__/

# Optional: ignore static exports
**/out/

# Optional: ignore lockfiles if you use only one package manager
# yarn.lock
# package-lock.json
# pnpm-lock.yaml
.dockerignore
docker-compose.yml